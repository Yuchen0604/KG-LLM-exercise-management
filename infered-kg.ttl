@prefix : <https://aet.cit.tum.de/tpo/example#> .
@prefix tpo: <https://aet.cit.tum.de/tpo#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://aet.cit.tum.de/tpo/example#> .

<https://aet.cit.tum.de/tpo/example#> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2002/07/owl#topObjectProperty
owl:topObjectProperty owl:inverseOf owl:topObjectProperty ;
                      rdf:type owl:SymmetricProperty ,
                               owl:TransitiveProperty .


###  https://aet.cit.tum.de/tpo#belongsToKnowledgeArea
<https://aet.cit.tum.de/tpo#belongsToKnowledgeArea> rdf:type owl:ObjectProperty ;
                                                    owl:inverseOf <https://aet.cit.tum.de/tpo#hasStandardizedCompetency> ;
                                                    rdfs:domain <https://aet.cit.tum.de/tpo#StandardizedCompetency> ;
                                                    rdfs:range <https://aet.cit.tum.de/tpo#KnowledgeArea> .


###  https://aet.cit.tum.de/tpo#belongsToUnit
<https://aet.cit.tum.de/tpo#belongsToUnit> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                                           rdfs:range <https://aet.cit.tum.de/tpo#CourseUnit> .


###  https://aet.cit.tum.de/tpo#extends
<https://aet.cit.tum.de/tpo#extends> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <https://aet.cit.tum.de/tpo#hasCompetencyDependency> ;
                                     rdf:type owl:TransitiveProperty .


###  https://aet.cit.tum.de/tpo#hasCompetencyDependency
<https://aet.cit.tum.de/tpo#hasCompetencyDependency> rdf:type owl:ObjectProperty ,
                                                              owl:TransitiveProperty ;
                                                     rdfs:domain <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                                                     rdfs:range <https://aet.cit.tum.de/tpo#CourseCompetency> .


###  https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy
<https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <https://aet.cit.tum.de/tpo#Competency> ;
                                                   rdfs:range <https://aet.cit.tum.de/tpo#CompetencyTaxonomy> .


###  https://aet.cit.tum.de/tpo#hasCourseCompetency
<https://aet.cit.tum.de/tpo#hasCourseCompetency> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf owl:topObjectProperty ;
                                                 rdfs:domain <https://aet.cit.tum.de/tpo#Course> ;
                                                 rdfs:range <https://aet.cit.tum.de/tpo#CourseCompetency> .


###  https://aet.cit.tum.de/tpo#hasCourseUnit
<https://aet.cit.tum.de/tpo#hasCourseUnit> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <https://aet.cit.tum.de/tpo#Course> ;
                                           rdfs:range <https://aet.cit.tum.de/tpo#CourseUnit> .


###  https://aet.cit.tum.de/tpo#hasPrerequisite
<https://aet.cit.tum.de/tpo#hasPrerequisite> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf owl:topObjectProperty ;
                                             rdfs:domain <https://aet.cit.tum.de/tpo#Course> ;
                                             rdfs:range <https://aet.cit.tum.de/tpo#Prerequisite> .


###  https://aet.cit.tum.de/tpo#hasStandardizedCompetency
<https://aet.cit.tum.de/tpo#hasStandardizedCompetency> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <https://aet.cit.tum.de/tpo#KnowledgeArea> ;
                                                       rdfs:range <https://aet.cit.tum.de/tpo#StandardizedCompetency> .


###  https://aet.cit.tum.de/tpo#linksTo
<https://aet.cit.tum.de/tpo#linksTo> rdf:type owl:ObjectProperty ;
                                     owl:inverseOf <https://aet.cit.tum.de/tpo#linksTo> ;
                                     rdf:type owl:SymmetricProperty ;
                                     rdfs:domain <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                                     rdfs:range <https://aet.cit.tum.de/tpo#StandardizedCompetency> .


###  https://aet.cit.tum.de/tpo#matches
<https://aet.cit.tum.de/tpo#matches> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <https://aet.cit.tum.de/tpo#hasCompetencyDependency> ,
                                                        [ owl:inverseOf <https://aet.cit.tum.de/tpo#hasCompetencyDependency>
                                                        ] ;
                                     owl:inverseOf <https://aet.cit.tum.de/tpo#matches> ;
                                     rdf:type owl:SymmetricProperty .


###  https://aet.cit.tum.de/tpo#requires
<https://aet.cit.tum.de/tpo#requires> rdf:type owl:ObjectProperty ;
                                      rdfs:subPropertyOf <https://aet.cit.tum.de/tpo#hasCompetencyDependency> ;
                                      rdf:type owl:TransitiveProperty .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:DatatypeProperty ;
                                       rdfs:range xsd:string .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:DatatypeProperty ;
                                 rdfs:range xsd:string .


###  https://aet.cit.tum.de/tpo#isOptional
<https://aet.cit.tum.de/tpo#isOptional> rdf:type owl:DatatypeProperty ;
                                        rdfs:range xsd:boolean ;
                                        rdfs:comment "Can be used to specify whether a course competency is optional" .


###  https://aet.cit.tum.de/tpo#semester
<https://aet.cit.tum.de/tpo#semester> rdf:type owl:DatatypeProperty ;
                                      rdfs:range xsd:string ;
                                      rdfs:comment "Can be used to describe the semester of an offered course" .


###  https://aet.cit.tum.de/tpo#shortName
<https://aet.cit.tum.de/tpo#shortName> rdf:type owl:DatatypeProperty ;
                                       rdfs:subPropertyOf owl:topDataProperty ;
                                       rdfs:range xsd:string .


###  https://aet.cit.tum.de/tpo#shortTitle
<https://aet.cit.tum.de/tpo#shortTitle> rdf:type owl:DatatypeProperty ;
                                        rdfs:subPropertyOf owl:topDataProperty ;
                                        rdfs:range xsd:string ;
                                        rdfs:comment "Can be used to specify the short title of a knowledge area" .


###  https://aet.cit.tum.de/tpo#softDueDate
<https://aet.cit.tum.de/tpo#softDueDate> rdf:type owl:DatatypeProperty ;
                                         rdfs:subPropertyOf owl:topDataProperty ;
                                         rdfs:range xsd:dateTime ;
                                         rdfs:comment "Can be used to specify the soft due date of a course competency" .


###  https://aet.cit.tum.de/tpo#unit
<https://aet.cit.tum.de/tpo#unit> rdf:type owl:DatatypeProperty ;
                                  rdfs:domain <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                                  rdfs:range xsd:integer ;
                                  rdfs:comment "Specifies the lecture unit number a course competency belongs to. Used to group competencies by week or topic in the course schedule." .


###  https://schema.org/endDate
<https://schema.org/endDate> rdf:type owl:DatatypeProperty ;
                             rdfs:range xsd:dateTime ;
                             rdfs:comment "Can be used to describe the end date of a course" .


###  https://schema.org/schemaVersion
<https://schema.org/schemaVersion> rdf:type owl:DatatypeProperty ;
                                   rdfs:range xsd:string ;
                                   rdfs:comment "Can be used to specify the version of a standardized competency" .


###  https://schema.org/startDate
<https://schema.org/startDate> rdf:type owl:DatatypeProperty ;
                               rdfs:range xsd:dateTime ;
                               rdfs:comment "Can be used to specify the start date of a course" .


#################################################################
#    Classes
#################################################################

###  https://aet.cit.tum.de/tpo#Competency
<https://aet.cit.tum.de/tpo#Competency> rdf:type owl:Class .


###  https://aet.cit.tum.de/tpo#CompetencyTaxonomy
<https://aet.cit.tum.de/tpo#CompetencyTaxonomy> rdf:type owl:Class ;
                                                owl:equivalentClass [ rdf:type owl:Class ;
                                                                      owl:oneOf ( <https://aet.cit.tum.de/tpo#Apply>
                                                                                  <https://aet.cit.tum.de/tpo#Create>
                                                                                  <https://aet.cit.tum.de/tpo#Evaluate>
                                                                                  <https://aet.cit.tum.de/tpo#Remember>
                                                                                  <https://aet.cit.tum.de/tpo#Understand>
                                                                                )
                                                                    ] .


###  https://aet.cit.tum.de/tpo#Course
<https://aet.cit.tum.de/tpo#Course> rdf:type owl:Class .


###  https://aet.cit.tum.de/tpo#CourseCompetency
<https://aet.cit.tum.de/tpo#CourseCompetency> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://aet.cit.tum.de/tpo#Competency> .


###  https://aet.cit.tum.de/tpo#CourseUnit
<https://aet.cit.tum.de/tpo#CourseUnit> rdf:type owl:Class .


###  https://aet.cit.tum.de/tpo#KnowledgeArea
<https://aet.cit.tum.de/tpo#KnowledgeArea> rdf:type owl:Class .


###  https://aet.cit.tum.de/tpo#Prerequisite
<https://aet.cit.tum.de/tpo#Prerequisite> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://aet.cit.tum.de/tpo#Competency> .


###  https://aet.cit.tum.de/tpo#StandardizedCompetency
<https://aet.cit.tum.de/tpo#StandardizedCompetency> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://aet.cit.tum.de/tpo#Competency> .


#################################################################
#    Individuals
#################################################################

###  https://aet.cit.tum.de/tpo#Analyze
<https://aet.cit.tum.de/tpo#Analyze> rdf:type owl:NamedIndividual ,
                                              <https://aet.cit.tum.de/tpo#CompetencyTaxonomy> .


###  https://aet.cit.tum.de/tpo#Apply
<https://aet.cit.tum.de/tpo#Apply> rdf:type owl:NamedIndividual ,
                                            <https://aet.cit.tum.de/tpo#CompetencyTaxonomy> .


###  https://aet.cit.tum.de/tpo#Create
<https://aet.cit.tum.de/tpo#Create> rdf:type owl:NamedIndividual ,
                                             <https://aet.cit.tum.de/tpo#CompetencyTaxonomy> .


###  https://aet.cit.tum.de/tpo#Evaluate
<https://aet.cit.tum.de/tpo#Evaluate> rdf:type owl:NamedIndividual ,
                                               <https://aet.cit.tum.de/tpo#CompetencyTaxonomy> .


###  https://aet.cit.tum.de/tpo#Remember
<https://aet.cit.tum.de/tpo#Remember> rdf:type owl:NamedIndividual ,
                                               <https://aet.cit.tum.de/tpo#CompetencyTaxonomy> .


###  https://aet.cit.tum.de/tpo#Understand
<https://aet.cit.tum.de/tpo#Understand> rdf:type owl:NamedIndividual ,
                                                 <https://aet.cit.tum.de/tpo#CompetencyTaxonomy> .


###  https://aet.cit.tum.de/tpo/example#Comp_AbstractClasses
:Comp_AbstractClasses rdf:type owl:NamedIndividual ,
                               <https://aet.cit.tum.de/tpo#Competency> ,
                               <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                      <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit7 ;
                      <https://aet.cit.tum.de/tpo#extends> :Comp_ClassDefinition ,
                                                           :Comp_Inheritance ,
                                                           :Comp_ObjectsAndClasses ;
                      <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_ClassDefinition ,
                                                                           :Comp_Inheritance ,
                                                                           :Comp_ObjectsAndClasses ;
                      <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Apply> ;
                      <https://aet.cit.tum.de/tpo#unit> 7 ;
                      <http://purl.org/dc/terms/description> "Apply abstract classes to define partial implementations and establish contracts that subclasses must fulfill. Use abstract methods to require specific behaviors while providing shared implementation through concrete methods." ;
                      <http://purl.org/dc/terms/title> "Abstract Classes" .


###  https://aet.cit.tum.de/tpo/example#Comp_AlgorithmDesign
:Comp_AlgorithmDesign rdf:type owl:NamedIndividual ,
                               <https://aet.cit.tum.de/tpo#Competency> ,
                               <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                      <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit3 ;
                      <https://aet.cit.tum.de/tpo#extends> :Comp_Loops ;
                      <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_Conditionals ,
                                                                           :Comp_Expressions ,
                                                                           :Comp_Loops ,
                                                                           :Comp_PrimitiveTypes ,
                                                                           :Comp_Variables ;
                      <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Analyze> ;
                      <https://aet.cit.tum.de/tpo#unit> 3 ;
                      <http://purl.org/dc/terms/description> "Analyze problems to design step-by-step algorithmic solutions using control structures. Break down complex problems into smaller sub-problems, trace algorithm execution, and compare alternative approaches for correctness and efficiency." ;
                      <http://purl.org/dc/terms/title> "Basic Algorithm Design" .


###  https://aet.cit.tum.de/tpo/example#Comp_ArrayListUsage
:Comp_ArrayListUsage rdf:type owl:NamedIndividual ,
                              <https://aet.cit.tum.de/tpo#Competency> ,
                              <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                     <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit4 ;
                     <https://aet.cit.tum.de/tpo#extends> :Comp_Arrays ;
                     <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_Arrays ,
                                                                          :Comp_Conditionals ,
                                                                          :Comp_Expressions ,
                                                                          :Comp_Loops ,
                                                                          :Comp_PrimitiveTypes ,
                                                                          :Comp_Variables ;
                     <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Apply> ;
                     <https://aet.cit.tum.de/tpo#unit> 4 ;
                     <http://purl.org/dc/terms/description> "Apply ArrayList and other Collection framework classes to manage dynamically-sized collections of objects. Use standard collection methods (add, remove, get, size) and understand when to choose collections over arrays." ;
                     <http://purl.org/dc/terms/title> "ArrayList and Collections" .


###  https://aet.cit.tum.de/tpo/example#Comp_Arrays
:Comp_Arrays rdf:type owl:NamedIndividual ,
                      <https://aet.cit.tum.de/tpo#Competency> ,
                      <https://aet.cit.tum.de/tpo#CourseCompetency> ;
             <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit4 ;
             <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_Conditionals ,
                                                                  :Comp_Expressions ,
                                                                  :Comp_Loops ,
                                                                  :Comp_PrimitiveTypes ,
                                                                  :Comp_Variables ;
             <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Apply> ;
             <https://aet.cit.tum.de/tpo#requires> :Comp_Conditionals ,
                                                   :Comp_Expressions ,
                                                   :Comp_Loops ,
                                                   :Comp_PrimitiveTypes ,
                                                   :Comp_Variables ;
             <https://aet.cit.tum.de/tpo#unit> 4 ;
             <http://purl.org/dc/terms/description> "Apply arrays to store and access fixed-size collections of elements using index-based access. Declare, initialize, and manipulate arrays including iteration, searching, and modification of elements." ;
             <http://purl.org/dc/terms/title> "Arrays" .


###  https://aet.cit.tum.de/tpo/example#Comp_ClassDefinition
:Comp_ClassDefinition rdf:type owl:NamedIndividual ,
                               <https://aet.cit.tum.de/tpo#Competency> ,
                               <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                      <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit5 ;
                      <https://aet.cit.tum.de/tpo#extends> :Comp_ObjectsAndClasses ;
                      <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_ObjectsAndClasses ;
                      <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Create> ;
                      <https://aet.cit.tum.de/tpo#unit> 5 ;
                      <http://purl.org/dc/terms/description> "Design and create complete class definitions that model real-world entities or abstract concepts. Produce well-structured classes with appropriate fields, methods, and constructors that exhibit high cohesion and clear responsibility." ;
                      <http://purl.org/dc/terms/title> "Class Definition" .


###  https://aet.cit.tum.de/tpo/example#Comp_CodingStyle
:Comp_CodingStyle rdf:type owl:NamedIndividual ,
                           <https://aet.cit.tum.de/tpo#Competency> ,
                           <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                  <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit12 ;
                  <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_ClassDefinition ,
                                                                       :Comp_Methods ,
                                                                       :Comp_ObjectsAndClasses ;
                  <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Apply> ;
                  <https://aet.cit.tum.de/tpo#requires> :Comp_ClassDefinition ,
                                                        :Comp_Methods ;
                  <https://aet.cit.tum.de/tpo#unit> 12 ;
                  <http://purl.org/dc/terms/description> "Apply consistent coding conventions including meaningful naming, proper indentation, appropriate spacing, and logical code organization. Follow established style guidelines to produce code that is readable, maintainable, and professional." ;
                  <http://purl.org/dc/terms/title> "Coding Style" .


###  https://aet.cit.tum.de/tpo/example#Comp_Conditionals
:Comp_Conditionals rdf:type owl:NamedIndividual ,
                            <https://aet.cit.tum.de/tpo#Competency> ,
                            <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                   <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit3 ;
                   <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_Expressions ,
                                                                        :Comp_PrimitiveTypes ,
                                                                        :Comp_Variables ;
                   <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Apply> ;
                   <https://aet.cit.tum.de/tpo#requires> :Comp_Expressions ,
                                                         :Comp_PrimitiveTypes ,
                                                         :Comp_Variables ;
                   <https://aet.cit.tum.de/tpo#unit> 3 ;
                   <http://purl.org/dc/terms/description> "Apply if, if-else, and switch statements to control program execution based on Boolean conditions. Use conditional logic to implement decision-making behavior, including handling multiple branches and nested conditions." ;
                   <http://purl.org/dc/terms/title> "Conditional Statements" .


###  https://aet.cit.tum.de/tpo/example#Comp_Constructors
:Comp_Constructors rdf:type owl:NamedIndividual ,
                            <https://aet.cit.tum.de/tpo#Competency> ,
                            <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                   <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit5 ;
                   <https://aet.cit.tum.de/tpo#extends> :Comp_Methods ;
                   <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_ClassDefinition ,
                                                                        :Comp_Methods ,
                                                                        :Comp_ObjectsAndClasses ;
                   <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Create> ;
                   <https://aet.cit.tum.de/tpo#unit> 5 ;
                   <http://purl.org/dc/terms/description> "Design and create constructors that properly initialize object state, including overloaded constructors and constructor chaining. Produce constructors that validate parameters and establish class invariants." ;
                   <http://purl.org/dc/terms/title> "Constructors" .


###  https://aet.cit.tum.de/tpo/example#Comp_Debugging
:Comp_Debugging rdf:type owl:NamedIndividual ,
                         <https://aet.cit.tum.de/tpo#Competency> ,
                         <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit11 ;
                <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_IDEUsage ;
                <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Apply> ;
                <https://aet.cit.tum.de/tpo#requires> :Comp_IDEUsage ;
                <https://aet.cit.tum.de/tpo#unit> 11 ;
                <http://purl.org/dc/terms/description> "Apply systematic debugging techniques to identify and fix program errors. Use debugger tools to set breakpoints, step through code, inspect variables, and trace execution flow to locate the root cause of defects." ;
                <http://purl.org/dc/terms/title> "Debugging" .


###  https://aet.cit.tum.de/tpo/example#Comp_Documentation
:Comp_Documentation rdf:type owl:NamedIndividual ,
                             <https://aet.cit.tum.de/tpo#Competency> ,
                             <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                    <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit12 ;
                    <https://aet.cit.tum.de/tpo#extends> :Comp_CodingStyle ;
                    <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_ClassDefinition ,
                                                                         :Comp_CodingStyle ,
                                                                         :Comp_Methods ,
                                                                         :Comp_ObjectsAndClasses ;
                    <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Apply> ;
                    <https://aet.cit.tum.de/tpo#unit> 12 ;
                    <http://purl.org/dc/terms/description> "Apply documentation practices including Javadoc comments for public APIs and inline comments for complex logic. Write clear, accurate documentation that explains purpose, parameters, return values, and important assumptions to support code maintenance." ;
                    <http://purl.org/dc/terms/title> "Code Documentation" .


###  https://aet.cit.tum.de/tpo/example#Comp_DynamicBinding
:Comp_DynamicBinding rdf:type owl:NamedIndividual ,
                              <https://aet.cit.tum.de/tpo#Competency> ,
                              <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                     <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit7 ;
                     <https://aet.cit.tum.de/tpo#extends> :Comp_Polymorphism ;
                     <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_ClassDefinition ,
                                                                          :Comp_Inheritance ,
                                                                          :Comp_MethodOverriding ,
                                                                          :Comp_ObjectsAndClasses ,
                                                                          :Comp_Polymorphism ,
                                                                          :Comp_PrimitiveTypes ,
                                                                          :Comp_StaticVsDynamicTypes ;
                     <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Analyze> ;
                     <https://aet.cit.tum.de/tpo#requires> :Comp_Inheritance ,
                                                           :Comp_MethodOverriding ;
                     <https://aet.cit.tum.de/tpo#unit> 7 ;
                     <http://purl.org/dc/terms/description> "Analyze how method calls are resolved at runtime based on the actual object type rather than the declared variable type. Trace polymorphic method invocations through class hierarchies to predict program behavior." ;
                     <http://purl.org/dc/terms/title> "Dynamic Binding" .


###  https://aet.cit.tum.de/tpo/example#Comp_Encapsulation
:Comp_Encapsulation rdf:type owl:NamedIndividual ,
                             <https://aet.cit.tum.de/tpo#Competency> ,
                             <https://aet.cit.tum.de/tpo#CourseCompetency> ;
                    <https://aet.cit.tum.de/tpo#belongsToUnit> :Unit5 ;
                    <https://aet.cit.tum.de/tpo#extends> :Comp_Fields ;
                    <https://aet.cit.tum.de/tpo#hasCompetencyDependency> :Comp_ClassDefinition ,
                                                                         :Comp_Fields ,
                                                                         :Comp_ObjectsAndClasses ;
                    <https://aet.cit.tum.de/tpo#hasCompetencyTaxonomy> <https://aet.cit.tum.de/tpo#Apply> ;
                    <https://aet.cit.tum.de/tpo#unit> 5 ;
